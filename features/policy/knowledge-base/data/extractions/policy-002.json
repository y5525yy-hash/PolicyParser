  "applicablePopulation": [{"title": "困难老年人", "text": "北京户籍的低保、低收入或符合条件的计划生育特殊家庭老年人。", "sourceChunkIds": ["chunk-9a174b048ae081f3", "chunk-9bcaecfa5bbaa097"]}],
  "benefits": [{"title": "分困难类型补贴", "text": "低保老年人每月300元，低收入未享受低保的老年人每月200元，其他符合条件的计划生育特殊家庭老年人每月100元。", "sourceChunkIds": ["chunk-7f4bbd4da5750629", "chunk-406d6a953fa796ce", "chunk-aaa4f9c2875f690a"]}],
  "materials": [{"title": "申请身份材料", "text": "窗口申请可出示居民身份证或户口簿，相关困难身份原则上通过政府信息共享核验。", "sourceChunkIds": ["chunk-6820d6dd21d8e050"]}],
  "procedures": [{"title": "自愿申请", "text": "本人、委托代理人或监护人可线上申请或到街道乡镇窗口申请。", "sourceChunkIds": ["chunk-6820d6dd21d8e050"]}],
  "restrictions": [{"title": "不得重复享受", "text": "困难老年人养老服务补贴、失能老年人护理补贴与残疾人对应生活或护理补贴不得重复享受，应按规定自主选择。", "sourceChunkIds": ["chunk-cbc14818a21b1eeb"]}],
