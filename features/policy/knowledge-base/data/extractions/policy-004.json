  "eligibility":[{"type":"allOf","sourceText":"参加城乡居民基本养老保险须具有本市户籍、年满16周岁且不是在校学生，并且不是国家机关事业单位工作人员，也不属于职工基本养老保险制度覆盖范围。","sourceChunkIds":["chunk-1ce68a31235bf346"],"conditions":[{"type":"condition","field":"hukou","operator":"equals","value":"北京市","sourceText":"本市户籍人员","sourceChunkIds":["chunk-1ce68a31235bf346"]},{"type":"condition","field":"age","operator":"greater_than_or_equal","value":16,"unit":"周岁","sourceText":"年满16周岁","sourceChunkIds":["chunk-1ce68a31235bf346"]},{"type":"condition","field":"isStudent","operator":"equals","value":false,"sourceText":"不含在校学生","sourceChunkIds":["chunk-1ce68a31235bf346"]},{"type":"condition","field":"isGovernmentOrPublicInstitutionStaff","operator":"equals","value":false,"sourceText":"非国家机关和事业单位工作人员","sourceChunkIds":["chunk-1ce68a31235bf346"]},{"type":"condition","field":"coveredByEmployeePensionInsurance","operator":"equals","value":false,"sourceText":"不属于职工基本养老保险制度覆盖范围","sourceChunkIds":["chunk-1ce68a31235bf346"]}]},{"type":"allOf","sourceText":"2015年1月1日以后新参保人员按月领取待遇，一般须为本市户籍、年满60周岁、累计缴费满15年，且未领取国家规定的基本养老保障待遇；不同年龄和进京时间存在过渡缴费规则。","sourceChunkIds":["chunk-c15f5c15708088cf","chunk-3c4a4117c2641fff","chunk-e11ff5c0e3d46814","chunk-ca40ae1bfc4f5064"],"conditions":[{"type":"condition","field":"age","operator":"greater_than_or_equal","value":60,"unit":"周岁","sourceText":"年满60周岁","sourceChunkIds":["chunk-c15f5c15708088cf"]},{"type":"condition","field":"contributionYears","operator":"greater_than_or_equal","value":15,"unit":"年","sourceText":"累计缴费满15年","sourceChunkIds":["chunk-c15f5c15708088cf"]},{"type":"condition","field":"receivesOtherBasicPensionBenefit","operator":"equals","value":false,"sourceText":"未领取国家规定的基本养老保障待遇","sourceChunkIds":["chunk-c15f5c15708088cf"]}]}],
  "applicablePopulation":[{"title":"北京户籍非职工养老覆盖城乡居民","text":"年满16周岁、非在校学生，且不属于机关事业单位或职工基本养老保险覆盖范围。","sourceChunkIds":["chunk-1ce68a31235bf346"]}],
  "benefits":[{"title":"2026年度缴费范围","text":"2026年最低年缴费1000元、最高年缴费9000元。","sourceChunkIds":["chunk-0cacd9f1b8b931fb"]},{"title":"养老待遇构成","text":"待遇由基础养老金和个人账户养老金构成，参保人死亡后个人账户余额可依法继承。","sourceChunkIds":["chunk-d823812748e67be9","chunk-0b98d50432489e9b"]}],
  "materials":[],"procedures":[],
  "restrictions":[{"title":"不得重复领取养老待遇","text":"不得同时领取职工基本养老保险和城乡居民基本养老保险待遇；同时领取的按规定终止居民养老关系并退回已领取基础养老金。","sourceChunkIds":["chunk-2e1cae0852b289f4"]}],
